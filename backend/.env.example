# Backend Environment Variables
# Copy this file to .env and fill in your real values before deploying

PORT=5000
NODE_ENV=production

# API Keys
GEMINI_API_KEY=<your_google_gemini_api_key>

# Set this to your frontend's public URL (no trailing slash)
CLIENT_URL=https://<your-frontend-domain.com>

# Firebase Configuration
FIREBASE_PROJECT_ID=<your_firebase_project_id>
# Optional: JSON string containing the Firebase service account private key (highly recommended for production hosting like Render)
# FIREBASE_SERVICE_ACCOUNT=<service_account_json_as_a_string>
